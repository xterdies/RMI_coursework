<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="003-1" author="platform">
        <createTable tableName="indicator_values">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="region_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_iv_region"
                             references="regions(id)" deleteCascade="true"/>
            </column>
            <column name="indicator_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_iv_indicator"
                             references="economic_indicators(id)"/>
            </column>
            <column name="year" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="DECIMAL(20,4)">
                <constraints nullable="false"/>
            </column>
            <column name="source_url" type="VARCHAR(512)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="indicator_values"
                             columnNames="region_id,indicator_id,year"
                             constraintName="uq_iv_region_indicator_year"/>
        <createIndex tableName="indicator_values" indexName="idx_iv_region_year">
            <column name="region_id"/>
            <column name="year"/>
        </createIndex>
        <createIndex tableName="indicator_values" indexName="idx_iv_indicator_year">
            <column name="indicator_id"/>
            <column name="year"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
